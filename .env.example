# Backend configuration. Copy to .env and fill in your values:
#   cp .env.example .env
#
# ── Database (MySQL mode: ./run-mysql.sh) ────────────────────────────────────
# For local MySQL, run: ./setup-mysql.sh && ./run-mysql.sh
# For Docker Compose, only DB_PASSWORD is needed; DB_URL is set automatically.
DB_URL=jdbc:mysql://localhost:3306/banking_system
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ── Run scripts (./run.sh) ───────────────────────────────────────────────────
# Port the backend listens on. Default: 8080.
# SERVER_PORT=8080
# Active Spring profile: dev (H2) or mysql. Default: dev.
# SPRING_PROFILES_ACTIVE=dev

# ── Application settings (both H2 and MySQL) ─────────────────────────────────
# CORS origins allowed (comma-separated). Defaults to http://localhost:5173 (Vite dev server).
# Set this when deploying to production.
APP_CORS_ORIGINS=http://localhost:5173

# Trust X-Forwarded-For header for rate limiting (only when behind a reverse proxy).
# Default: false. Set to true in production if using a trusted proxy (e.g., Nginx, Cloudflare).
APP_TRUST_PROXY=false

# Rate limit: max requests per IP per endpoint per 60 seconds.
# Affects: /api/auth/login, /api/auth/register, /api/accounts/lookup
APP_RATE_LIMIT_MAX_REQUESTS=10
