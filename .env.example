# Copy to .env and fill in your values:
#   cp .env.example .env
#
# ── Local MySQL (./run-mysql.sh) ─────────────────────────────────────────────
# Then run: ./setup-mysql.sh && ./run-mysql.sh
DB_URL=jdbc:mysql://localhost:3306/banking_system
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# ── Docker Compose (docker compose up) ───────────────────────────────────────
# docker-compose.yml only needs DB_PASSWORD (and optionally DB_USERNAME).
# DB_URL is set automatically to jdbc:mysql://db:3306/banking_system inside
# the compose network — you do not need to change it here for Docker.
