# Frontend configuration (optional).
#
# API base URL for production builds (when not behind a dev proxy).
# Default: empty (uses Vite proxy to http://localhost:8080 in dev mode).
# Typically set during build: VITE_API_URL=https://api.example.com npm run build
# VITE_API_URL=http://localhost:8080
#
# Safe for frontend: public API base URL only.
# Never put database passwords, API secrets, or signing keys here.
#
# Docker Compose: BACKEND_URL is set automatically by docker-compose.yml
# for the dev proxy (http://backend:8080) and should not be changed here.
